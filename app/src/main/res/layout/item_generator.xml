<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/generator_item_background"
    android:padding="12dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:gravity="center_vertical">

    <!-- Icono/Emoji del generador -->
    <TextView
        android:id="@+id/tvEmoji"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="☕"
        android:textSize="32sp"
        android:gravity="center" />

    <!-- Info del generador -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coffee Stand"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvOwned"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tienes: 0"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/tvProduction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ 0/seg"
            android:textSize="12sp"
            android:textColor="@color/secondary" />

    </LinearLayout>

    <!-- Botón de compra -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <Button
            android:id="@+id/btnBuy"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="90dp"
            android:text="💰 100"
            android:textSize="11sp"
            android:textColor="@color/white"
            android:background="@drawable/upgrade_button_background"
            android:paddingHorizontal="8dp"
            android:ellipsize="end"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="@color/warning"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
