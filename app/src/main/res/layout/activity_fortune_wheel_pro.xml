<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_garage_scene"
    android:gravity="center"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_glass"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:text="🎡 RULETA DE LA FORTUNA"
            android:textColor="#FFD700"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif-medium"
            android:text="💰 0"
            android:textColor="#FFD700"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Wheel Container -->
    <FrameLayout
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="20dp">

        <!-- Wheel placeholder -->
        <ImageView
            android:id="@+id/wheelImage"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:src="@drawable/fortune_wheel" />

        <!-- Arrow indicator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="-5dp"
            android:text="▼"
            android:textColor="#FFD700"
            android:textSize="36sp"
            android:shadowColor="#80000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <!-- Center jewel -->
        <TextView
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_gravity="center"
            android:background="@drawable/wheel_center"
            android:gravity="center"
            android:text="💎"
            android:textSize="26sp" />
    </FrameLayout>

    <!-- Result Container -->
    <LinearLayout
        android:id="@+id/resultContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/card_glass"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="invisible">

        <TextView
            android:id="@+id/tvResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="🎉 ¡GANASTE!"
            android:textColor="#FFD700"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tvResultPrize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="💰 +10,000"
            android:textColor="#4CAF50"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- Spin Button -->
    <Button
        android:id="@+id/btnSpin"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/btn_gold"
        android:fontFamily="sans-serif-black"
        android:text="🎰 GIRAR"
        android:textAllCaps="false"
        android:textColor="#1A1A2E"
        android:textSize="18sp" />

    <!-- Back Button -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:background="@android:color/transparent"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="24dp"
        android:text="← Volver"
        android:textAllCaps="false"
        android:textColor="#80FFFFFF"
        android:textSize="14sp" />

</LinearLayout>
