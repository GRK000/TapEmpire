<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:orientation="vertical"
    tools:context=".WorldsActivity">

    <!-- Header con mundo actual -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="16dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌍 MUNDOS"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/secondary"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvCurrentWorld"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 Mundo Actual: Garage Startup"
            android:textSize="16sp"
            android:textColor="@color/coins_gold"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvWorldBonus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bonus: x1.00 producción"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvCoins"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 0"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/coins_gold"
            android:gravity="center"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Lista de mundos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/worldsRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
