<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:centerX="50%"
                android:centerY="50%"
                android:startColor="#407C4DFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Shadow -->
    <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#40000000" />
        </shape>
    </item>

    <!-- Main button gradient -->
    <item android:top="4dp" android:left="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:centerX="50%"
                android:centerY="35%"
                android:startColor="#9C7CFF"
                android:centerColor="#7C4DFF"
                android:endColor="#5C3ED6" />
            <stroke
                android:width="3dp"
                android:color="#B39DFF" />
        </shape>
    </item>

    <!-- Inner highlight -->
    <item android:top="8dp" android:left="8dp" android:right="8dp" android:bottom="60dp">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#40FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
